# Top level .editorconfig file used for this project used everywhere
root = true

#### General Formatting Options ####

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# Text & CMake Files
[*.{txt,md,cmake}]
indent_style = tab

# C++ Source Code
[*.{cpp,hpp,inl}]
indent_style = tab

# Data & Serialization Files
[*.{json,xml}]
indent_style = tab

# NPM Package Files
[package*.json]
indent_style = space
indent_size = 2
